# Database
DB_PASSWORD=changeme_dev

# JWT — generate secret with: openssl rand -hex 32
# WARNING: the app refuses to start if JWT_SECRET contains "changeme" or is shorter than 32 chars
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32
JWT_EXPIRE_HOURS=1

# bcrypt work factor (default 12 — increase on faster hardware)
BCRYPT_ROUNDS=12

# LLM Provider — MVP: OpenAI Direct (keine echten internen Dokumente)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Post-MVP: Azure OpenAI EU — uncomment and set before first real internal document
# LITELLM_BASE_URL=https://<resource>.openai.azure.com/
# LITELLM_API_VERSION=2024-02-01
# LITELLM_API_KEY=<azure-key>
